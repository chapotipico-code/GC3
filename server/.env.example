# Sunucuda bu dosyayı .env olarak kopyalayıp değerleri doldur
# cp .env.example .env  sonra nano .env ile düzenle

# PostgreSQL bağlantısı (seed.js ve sunucuda kurarken oluşturacağız)
DATABASE_URL=postgres://gc_user:GUCLU_DB_SIFRESI@localhost:5432/gc_db

# Oturum imzalama anahtarı — rastgele uzun bir metin yaz (kuyrukta üreteceğiz)
JWT_SECRET=degistir_bunu_uzun_rastgele_bir_metinle

# Backend portu
PORT=3001

# İlk patron hesabı (seed.js sadece ilk kurulumda kullanır)
PATRON_USER=patron
PATRON_PASS=Mahmut48
